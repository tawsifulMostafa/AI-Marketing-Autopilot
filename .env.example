# MarketFlow AI local environment
# Copy this file to .env and replace placeholder values before running the API.

APP_NAME="MarketFlow AI API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/v1

# PostgreSQL / Supabase
# Local example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketflow_ai
DATABASE_URL=
DATABASE_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=marketflow-assets

# AI providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-1

# Shopify
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_admin_api_access_token
SHOPIFY_API_VERSION=2026-04
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# WooCommerce
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Workers / cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
